# Database — choose one:
# Local Docker: docker compose up -d
# DATABASE_URL=postgresql://gametracker:gametracker@localhost:5432/gametracker
# Neon (serverless PostgreSQL):
DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXXX-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=test

# Optional: IGDB (Twitch Developer app — Client ID + OAuth App Access Token flow)
# Server uses client credentials; set both for search from IGDB.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Public URL for auth callbacks (default http://localhost:3000)
AUTH_URL=http://localhost:3000
